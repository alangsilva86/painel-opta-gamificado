VITE_APP_TITLE="Painel Opta"
VITE_APP_LOGO="/logo.svg"
# Banco
DATABASE_URL="mysql://user:password@host:3306/database?ssl={\"rejectUnauthorized\":true}"
# Sessão local (apenas para assinar cookies)
JWT_SECRET="change-me"
# LLM opcional
OPENAI_API_URL=""
OPENAI_API_KEY="your-openai-api-key"
OPENAI_MODEL="gpt-4o-mini"
# Infraestrutura (server-only)
PORT=3000
ZOHO_CLIENT_ID="your-zoho-client-id"
ZOHO_CLIENT_SECRET="your-zoho-client-secret"
ZOHO_REFRESH_TOKEN="your-zoho-refresh-token"
PROCFY_API_TOKEN="your-procfy-bearer-token"
# Docs oficiais do Procfy usam https://api.procfy.io/api/v1.
# Se a sua conta usa outro host, sobrescreva aqui.
PROCFY_BASE_URL="https://api.procfy.io/api/v1"

VITE_TRPC_URL="http://localhost:3000/api/trpc"
GESTAO_PASSWORD_HASH="sha256-hash-da-senha-da-gestao"
